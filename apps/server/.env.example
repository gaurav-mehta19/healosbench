# ── Anthropic ──────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ────────────────────────────────────────────
# Local Postgres: create the DB first with:
#   psql -U postgres -c "CREATE DATABASE healosbench;"
DATABASE_URL=postgres://postgres:postgres@localhost:5432/healosbench

# ── Auth (Better-Auth) ──────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace_with_32_plus_char_random_string

# URL this server is reachable at (used by Better-Auth for cookie domain)
BETTER_AUTH_URL=http://localhost:8787

# Which origin is allowed to call this server (the Next.js dev URL)
CORS_ORIGIN=http://localhost:3001

# ── Node environment ────────────────────────────────────
NODE_ENV=development

# ── Server port ─────────────────────────────────────────
PORT=8787
